# Spotify Configuration
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://your-frontend-domain/callback
SPOTIFY_SCOPES=user-top-read,user-read-recently-played,playlist-modify-public,playlist-modify-private

# Database Configuration (Supabase)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
DATABASE_URL=your_postgresql_connection_string

# Backend Configuration
BACKEND_PORT=3001
NODE_ENV=development
JWT_SECRET=your_jwt_secret_for_session_tokens

# Frontend Configuration
VITE_API_URL=https://your-backend-url
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id

# Encryption
ENCRYPTION_KEY=your_encryption_key_for_token_storage

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# CORS
FRONTEND_URL=https://your-frontend-domain
BACKEND_HOST=127.0.0.1
