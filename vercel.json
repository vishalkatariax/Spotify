{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "^/callback$",
      "destination": "/index.html"
    },
    {
      "source": "^/(.*)$",
      "destination": "/index.html"
    }
  ]
}
